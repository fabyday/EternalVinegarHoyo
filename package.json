{
  "name": "EternalVinegarHoyo",
  "version": "1.0.0",
  "description": "Play Steam, HoyoVerse, and other games. custom Wine Launcher for MacOS",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "pnpm test:jest",
    "test:main": "pnpm build && electron .",
    "test:renderer": "webpack --config src/Renderer/webpack.dev.ts",
    "build:main": "webpack --config src/Main/webpack.prod.ts",
    "build:preload": "webpack --config src/Preload/webpack.prod.ts",
    "build:renderer": "webpack --config src/Renderer/webpack.prod.ts",
    "build": "pnpm build:preload && pnpm build:renderer && pnpm build:main",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "prestart": "pnpm build",
    "start": "electron .",
    "storybook": "storybook dev -c ./src/Renderer/.storybook -p 6006",
    "build-storybook": "storybook build -c ./src/Renderer/.storybook",
    "screenshot": "pnpm build-storybook && node scripts/capture-storybook-screenshot.mjs",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch"
  },
  "keywords": [
    "game",
    "wine",
    "launcher",
    "steam",
    "javascript",
    "hoyoverse",
    "steam",
    "eternal return"
  ],
  "author": "fabyday",
  "license": "MIT",
  "build": {
    "appId": "com.fabyday.bdih-launcher",
    "productName": "BDIH Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@storybook/addon-essentials": "8.6.0",
    "@storybook/addon-interactions": "8.6.0",
    "@storybook/addon-postcss": "^2.0.0",
    "@storybook/addon-styling-webpack": "1.0.1",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
    "@storybook/react": "8.6.0",
    "@storybook/react-webpack5": "8.6.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-dev-server": "^4.7.2",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.3.0",
    "css-loader": "^7.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "storybook": "8.6.0",
    "style-loader": "^4.0.0",
    "tailwind": "4",
    "tailwindcss": "^4.2.2",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "overrides": {}
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/dom": "^0.4.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dnd-kit": "^0.0.2",
    "electron-updater": "^6.8.3",
    "i18next": "^26.2.0",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.8",
    "xterm": "^5.3.0",
    "zustand": "^5.0.12"
  }
}
