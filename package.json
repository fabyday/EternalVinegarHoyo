  "description": "Play Steam, HoyoVerse, and other games. custom Wine Launcher for MacOS",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "pnpm test:jest",
    "test:main": "webpack --config src/main/webpack.dev.ts && electron ./dist/main/main.js",
    "test:renderer": "webpack --config src/renderer/webpack.dev.ts",
    "build": "webpack --config webpack.config.js",
    "start": "electron .",
    "storybook": "storybook dev -c ./src/Renderer/.storybook -p 6006",
    "build-storybook": "storybook build",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch"
  },
  "keywords": [
    "game",
    "javascript",
    "hoyoverse",
    "steam",
    "eternal return"
  ],
  "author": "fabyday",
  "license": "MIT",
